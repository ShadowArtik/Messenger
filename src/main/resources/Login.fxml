<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.LoginController"
      alignment="CENTER"
      spacing="12"
      style="-fx-background-color: #1E1F22;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Messenger Login"
           style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField"
               promptText="Username"
               maxWidth="260"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="260"/>

    <HBox alignment="CENTER" spacing="10">
        <Button text="Login" onAction="#onLoginClick"/>
        <Button text="Register" onAction="#onRegisterClick"/>
    </HBox>

</VBox>