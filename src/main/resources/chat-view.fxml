<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controller.MessengerController">

    <left>
        <VBox prefWidth="220" styleClass="sidebar">

            <HBox alignment="CENTER_LEFT"
                  spacing="10"
                  styleClass="sidebar-header">

                <Label text="Chats" styleClass="sidebar-title"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button fx:id="addChatButton"
                        text="+"
                        onAction="#onAddChatButtonClick"
                        styleClass="add-chat-button"/>
            </HBox>

            <HBox alignment="CENTER_LEFT"
                  spacing="4"
                  styleClass="chat-search-box">

                <TextField fx:id="chatSearchField"
                           promptText="Search chats..."
                           HBox.hgrow="ALWAYS"
                           styleClass="chat-search-field"/>

                <Label fx:id="clearChatSearchLabel"
                       text="×"
                       visible="false"
                       managed="false"
                       onMouseClicked="#onClearChatSearchClick"
                       styleClass="clear-search-label"/>
            </HBox>

            <ListView fx:id="contactsListView"
                      VBox.vgrow="ALWAYS"/>

            <VBox fx:id="currentUserBox"
                  spacing="8"
                  styleClass="current-user-panel">

                <HBox alignment="CENTER_LEFT"
                      spacing="8">

                    <StackPane fx:id="currentUserAvatar"/>

                    <VBox spacing="2"
                          HBox.hgrow="ALWAYS">

                        <Label fx:id="currentUserDisplayNameLabel"
                               text="Display Name"
                               styleClass="current-user-name"/>

                        <Label fx:id="currentUserUsernameLabel"
                               text="@username"
                               styleClass="current-user-username"/>
                    </VBox>

                    <Button text="Edit"
                            onAction="#onEditProfileClick"
                            styleClass="profile-edit-button"/>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <Button text="Logout"
                            onAction="#onLogoutClick"
                            styleClass="logout-button"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane>

            <VBox fx:id="emptyChatBox"
                  alignment="CENTER"
                  spacing="10"
                  styleClass="empty-chat-box">

                <Label text="Select a chat"
                       styleClass="empty-chat-title"/>

                <Label text="Choose a chat from the left panel to start messaging"
                       styleClass="empty-chat-subtitle"/>

            </VBox>

            <VBox fx:id="chatArea"
                  spacing="10"
                  styleClass="chat-area"
                  visible="false"
                  managed="false">
                <HBox fx:id="chatHeaderBox"
                      alignment="CENTER_LEFT"
                      spacing="10"
                      styleClass="chat-header">

                    <StackPane fx:id="chatAvatar"/>

                    <HBox alignment="CENTER_LEFT"
                          spacing="8"
                          HBox.hgrow="ALWAYS">

                        <Label fx:id="chatTitleLabel"
                               text="Bot"
                               styleClass="chat-title"/>

                        <Label fx:id="typingLabel"
                               text=""
                               visible="false"
                               styleClass="typing-label"/>
                    </HBox>

                    <Button fx:id="menuButton"
                            text="⋮"
                            onAction="#onMenuButtonClick"
                            styleClass="dots-button"/>
                </HBox>

                <ListView fx:id="messagesListView"
                          styleClass="messages-list"
                          VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      styleClass="message-input-box">

                    <TextField fx:id="messageTextField"
                               promptText="Enter message"
                               HBox.hgrow="ALWAYS"/>

                    <Button fx:id="sendButton"
                            text="Send"
                            onAction="#onSendButtonClick"
                            styleClass="send-button"/>
                </HBox>
            </VBox>

            <StackPane fx:id="createChatOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="245"
                      maxHeight="245"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Create new chat"
                           styleClass="dialog-title"/>

                    <Label text="Enter username of the user you want to message"
                           styleClass="dialog-subtitle"/>

                    <TextField fx:id="createChatUsernameField"
                               promptText="Username"
                               styleClass="dialog-input"/>

                    <Label fx:id="createChatErrorLabel"
                           text=""
                           visible="false"
                           managed="false"
                           styleClass="dialog-error"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelCreateChatClick"
                                styleClass="secondary-button"/>

                        <Button text="Create"
                                onAction="#onConfirmCreateChatClick"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="renameChatOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="245"
                      maxHeight="245"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Rename chat"
                           styleClass="dialog-title"/>

                    <Label text="Enter a new name for this chat"
                           styleClass="dialog-subtitle"/>

                    <TextField fx:id="renameChatNameField"
                               promptText="Chat name"
                               styleClass="dialog-input"/>

                    <Label fx:id="renameChatErrorLabel"
                           text=""
                           visible="false"
                           managed="false"
                           styleClass="dialog-error"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Reset to profile name"
                                onAction="#onResetRenameChatClick"
                                styleClass="secondary-button"/>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button text="Cancel"
                                onAction="#onCancelRenameChatClick"
                                styleClass="secondary-button"/>

                        <Button text="Save"
                                onAction="#onConfirmRenameChatClick"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="createGroupOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox alignment="CENTER_LEFT"
                      spacing="14"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="360"
                      maxHeight="360"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Create group chat"
                           styleClass="dialog-title"/>

                    <Label text="Enter group name and choose members"
                           styleClass="dialog-subtitle"/>

                    <TextField fx:id="groupNameField"
                               promptText="Group name"
                               styleClass="dialog-input"/>

                    <ListView fx:id="groupMembersListView"
                              prefHeight="160"
                              styleClass="group-members-list"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelCreateGroupClick"
                                styleClass="secondary-button"/>

                        <Button text="Create"
                                onAction="#onConfirmCreateGroupClick"
                                styleClass="primary-button"/>

                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="groupInfoOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox alignment="CENTER_LEFT"
                      spacing="16"
                      prefWidth="380"
                      maxWidth="380"
                      styleClass="modal-window"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Group info"
                           styleClass="modal-title"/>

                    <Label fx:id="groupInfoNameLabel"
                           styleClass="group-info-title"/>

                    <Label text="Members"
                           styleClass="modal-small-label"/>

                    <ListView fx:id="groupInfoMembersListView"
                              prefHeight="150"
                              styleClass="members-list-view"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button fx:id="addMembersButton"
                                text="Add members"
                                onAction="#onAddMembersClick"
                                styleClass="primary-button"/>

                        <Button text="Close"
                                onAction="#onCloseGroupInfoClick"
                                styleClass="secondary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="addMembersOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox alignment="CENTER_LEFT"
                      spacing="16"
                      prefWidth="420"
                      maxWidth="420"
                      styleClass="modal-window"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Add members"
                           styleClass="modal-title"/>

                    <Label text="Select users you want to add to this group"
                           styleClass="dialog-subtitle"/>

                    <ListView fx:id="addMembersListView"
                              prefHeight="260"
                              styleClass="members-list-view"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelAddMembersClick"
                                styleClass="secondary-button"/>

                        <Button text="Add"
                                onAction="#onConfirmAddMembersClick"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="leaveGroupOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="205"
                      maxHeight="205"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Leave group?"
                           styleClass="dialog-title"/>

                    <Label text="This group will be removed from your chat list."
                           styleClass="dialog-subtitle"
                           wrapText="true"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelLeaveGroupClick"
                                styleClass="secondary-button"/>

                        <Button text="Leave"
                                onAction="#onConfirmLeaveGroupClick"
                                styleClass="danger-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="deleteChatOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="220"
                      maxHeight="220"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Delete chat"
                           styleClass="dialog-title"/>

                    <Label text="This chat will be removed from your chat list."
                           styleClass="dialog-subtitle"/>

                    <Label text="This action cannot be undone."
                           styleClass="dialog-error"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelDeleteChatClick"
                                styleClass="secondary-button"/>

                        <Button text="Delete"
                                onAction="#onConfirmDeleteChatClick"
                                styleClass="danger-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="clearChatOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="220"
                      maxHeight="220"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Clear chat"
                           styleClass="dialog-title"/>

                    <Label text="All messages in this chat will be deleted."
                           styleClass="dialog-subtitle"/>

                    <Label text="This action cannot be undone."
                           styleClass="dialog-error"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelClearChatClick"
                                styleClass="secondary-button"/>

                        <Button text="Clear"
                                onAction="#onConfirmClearChatClick"
                                styleClass="danger-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="logoutOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox alignment="CENTER_LEFT"
                      spacing="18"
                      prefWidth="360"
                      maxWidth="360"
                      prefHeight="210"
                      maxHeight="210"
                      styleClass="create-chat-dialog"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Log out?"
                           styleClass="dialog-title"/>

                    <Label text="Are you sure you want to log out of your account?"
                           styleClass="dialog-subtitle"
                           wrapText="true"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelLogoutClick"
                                styleClass="secondary-button"/>

                        <Button text="Logout"
                                onAction="#onConfirmLogoutClick"
                                styleClass="danger-button"/>
                    </HBox>

                </VBox>

            </StackPane>

            <StackPane fx:id="profileOverlay"
                       visible="false"
                       managed="false"
                       styleClass="modal-overlay"
                       onMouseClicked="#onOverlayBackgroundClick">

                <VBox alignment="CENTER_LEFT"
                      spacing="12"
                      styleClass="profile-card"
                      onMouseClicked="#onModalWindowClick">

                    <Label text="Profile"
                           styleClass="modal-title"/>

                    <Label fx:id="profileUsernameLabel"
                           text="@username"
                           styleClass="profile-username-label"/>

                    <Label text="Display name"
                           styleClass="profile-field-label"/>

                    <TextField fx:id="profileDisplayNameField"
                               promptText="Display name"
                               styleClass="modal-text-field"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelProfileClick"
                                styleClass="secondary-button"/>

                        <Button text="Save"
                                onAction="#onSaveProfileClick"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

        </StackPane>

    </center>

</BorderPane>
