<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controller.MessengerController">

    <left>
        <VBox prefWidth="220" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT"
                  spacing="10"
                  styleClass="sidebar-header">

                <Label text="Chats" styleClass="sidebar-title"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="+"
                        onAction="#onCreateChatClick"
                        styleClass="add-chat-button"/>
            </HBox>

            <ListView fx:id="contactsListView"
                      VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <StackPane>

            <VBox spacing="10" styleClass="chat-area">
                <HBox fx:id="chatHeaderBox"
                      alignment="CENTER_LEFT"
                      spacing="10"
                      styleClass="chat-header">

                    <StackPane fx:id="chatAvatar"/>

                    <Label fx:id="chatTitleLabel"
                           text="Bot"
                           styleClass="chat-title"
                           HBox.hgrow="ALWAYS"/>

                    <Button fx:id="menuButton"
                            text="⋮"
                            onAction="#onMenuButtonClick"
                            styleClass="dots-button"/>
                </HBox>

                <ListView fx:id="messagesListView"
                          styleClass="messages-list"
                          VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      styleClass="message-input-box">

                    <TextField fx:id="messageTextField"
                               promptText="Enter message"
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Send"
                            onAction="#onSendButtonClick"
                            styleClass="send-button"/>
                </HBox>
            </VBox>

            <VBox fx:id="dropdownMenu"
                  visible="false"
                  managed="false"
                  prefWidth="130"
                  maxWidth="130"
                  styleClass="dropdown-menu"
                  StackPane.alignment="TOP_LEFT"
                  translateX="190"
                  translateY="55">

                <Button text="Clear chat"
                        onAction="#onClearChatClick"
                        styleClass="dropdown-item"/>

                <Button text="Rename"
                        onAction="#onRenameChatClick"
                        styleClass="dropdown-item"/>

                <Button text="Delete chat"
                        onAction="#onDeleteChatClick"
                        styleClass="dropdown-item"/>
            </VBox>

            <StackPane fx:id="createChatOverlay"
                       visible="false"
                       styleClass="modal-overlay">

                <VBox spacing="14"
                      alignment="CENTER_LEFT"
                      prefWidth="380"
                      maxWidth="380"
                      prefHeight="245"
                      maxHeight="245"
                      styleClass="create-chat-dialog">

                    <Label text="Create new chat"
                           styleClass="dialog-title"/>

                    <Label text="Enter username of the user you want to message"
                           styleClass="dialog-subtitle"/>

                    <TextField fx:id="createChatUsernameField"
                               promptText="Username"
                               styleClass="dialog-input"/>

                    <Label fx:id="createChatErrorLabel"
                           text=""
                           visible="false"
                           managed="false"
                           styleClass="dialog-error"/>

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Cancel"
                                onAction="#onCancelCreateChatClick"
                                styleClass="secondary-button"/>

                        <Button text="Create"
                                onAction="#onConfirmCreateChatClick"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </StackPane>

        </StackPane>
    </center>

</BorderPane>