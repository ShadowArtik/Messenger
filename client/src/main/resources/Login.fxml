<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.LoginController"
      alignment="CENTER"
      spacing="14"
      style="-fx-background-color: #1E1F22;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox fx:id="loginBox" alignment="CENTER" spacing="12">
        <Label text="Login"
               style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>

        <TextField fx:id="loginUsernameField"
                   promptText="Username"
                   maxWidth="260"/>

        <PasswordField fx:id="loginPasswordField"
                       promptText="Password"
                       maxWidth="260"/>

        <Button text="Login" onAction="#onLoginClick"/>

        <Button text="Create new account"
                onAction="#showRegisterForm"
                style="-fx-background-color: transparent; -fx-text-fill: #5B9DFF;"/>
    </VBox>

    <VBox fx:id="registerBox" alignment="CENTER" spacing="12"
          visible="false" managed="false">

        <Label text="Register"
               style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>

        <TextField fx:id="registerUsernameField"
                   promptText="Username"
                   maxWidth="260"/>

        <TextField fx:id="displayNameField"
                   promptText="Display name"
                   maxWidth="260"/>

        <PasswordField fx:id="registerPasswordField"
                       promptText="Password"
                       maxWidth="260"/>

        <Button text="Create account" onAction="#onRegisterClick"/>

        <Button text="Back to login"
                onAction="#showLoginForm"
                style="-fx-background-color: transparent; -fx-text-fill: #5B9DFF;"/>
    </VBox>

</VBox>